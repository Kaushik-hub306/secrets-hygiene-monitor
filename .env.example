# Secrets Hygiene Monitor -- Environment config

# Server
HOST=127.0.0.1
PORT=8000
APP_ENV=development

# CORS -- comma-separated allowed origins (NO wildcards in production)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Disable Swagger UI in production
DISABLE_DOCS=false

# GitHub OAuth (for later)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database (SQLite for MVP)
DATABASE_URL=sqlite:///./data/secrets_monitor.db
