# GitHub Configuration\nGITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\nGITHUB_REPOS=repo1,repo2,repo3\nGITHUB_SCAN_DEPTH=100\nGITHUB_ORG=your-organization\n\n# AWS Configuration\nAWS_REGION=us-east-1\nAWS_ACCOUNT_ID=123456789012\nAWS_ACCESS_KEY_ID=AKIA...\nAWS_SECRET_ACCESS_KEY=...\n\n# Slack Configuration\nSLACK_WEBHOOK_URL=https://hooks.slack.com/services/...\nSLACK_CHANNEL=#security-alerts\nSLACK_MENTION_ON_CRITICAL=@security-team\n\n# Email Configuration\nSES_SENDER_EMAIL=security@yourcompany.com\nSES_RECIPIENT_EMAILS=security-team@yourcompany.com\n\n# Application Configuration\nCOMPANY_NAME=YourCompany\nDEBUG=false\nLOG_LEVEL=INFO\nSCAN_INTERVAL_HOURS=24\n\n# Database Configuration\nDYNAMODB_TABLE_AUDIT=secrets-hygiene-audit-logs\nDYNAMODB_TABLE_INCIDENTS=secrets-hygiene-incidents\nRDS_HOST=localhost\nRDS_PORT=5432\nRDS_DATABASE=secrets_monitor\nRDS_USER=postgres\nRDS_PASSWORD=postgres\n\n# Feature Flags\nENABLE_PUBLIC_GITHUB_SCAN=true\nENABLE_AUTO_ROTATION=true\nENABLE_S3_SCANNING=true\nENABLE_CLOUDWATCH_SCANNING=false\n